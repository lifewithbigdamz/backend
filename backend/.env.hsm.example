# HSM Gateway Configuration

# HSM Provider Selection
# Options: aws-kms, hashicorp-vault, gcp-kms
HSM_PROVIDER=aws-kms

# AWS KMS Configuration (if using AWS KMS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# HashiCorp Vault Configuration (if using Vault)
VAULT_ADDR=https://vault.example.com:8200
VAULT_TOKEN=your_vault_token
VAULT_NAMESPACE=your_namespace  # Optional for Enterprise Vault

# GCP KMS Configuration (if using GCP KMS)
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION_ID=global
GCP_KEY_RING_ID=your-key-ring-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Stellar Network Configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban Contract Configuration
REVOCATION_CONTRACT_ID=CA3D5SRYHA6ZKXW5UQY4Q4QY4QY4QY4QY4QY4QY4QY4QY4QY4QY4QY4QY4Q

# HSM Key Mapping (JSON format)
# Maps signer addresses to their corresponding HSM key IDs
HSM_KEY_MAPPING={"0x1234567890123456789012345678901234567890":"arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"}

# Individual HSM Key Environment Variables (alternative to JSON mapping)
# Format: HSM_KEY_<ADDRESS_WITHOUT_0X_AND_UPPERCASE>
HSM_KEY_1234567890123456789012345678901234567890=arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012

# Security Configuration
# Admin addresses (comma-separated) that can access HSM operations
ADMIN_ADDRESSES=0x1234567890123456789012345678901234567890,0xabcdefabcdefabcdefabcdefabcdefabcdefabcd

# HSM Security Options
HSM_IP_WHITELIST=192.168.1.100,10.0.0.50  # Optional IP whitelist
HSM_TIME_RESTRICTION=false  # Enable business hours restriction
HSM_BUSINESS_HOURS=9-17  # Business hours (24-hour format)

# Fallback Configuration
HSM_FALLBACK_ENABLED=true  # Enable fallback to mock implementation in development
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Database Configuration (for Admin model)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vesting_vault
DB_USER=postgres
DB_PASSWORD=your_db_password

# Audit Logging
AUDIT_LOG_LEVEL=info
AUDIT_LOG_FILE=logs/audit.log

# Rate Limiting
HSM_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
HSM_RATE_LIMIT_MAX_REQUESTS=10  # 10 requests per minute
